{
  "uid": "ml-latency-slo",
  "title": "ML Service: SLO Латентность p95 (Цель < 200ms)",
  "tags": ["ml", "slo", "module-8"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "p95 Латентность инференса vs SLO Target",
      "type": "timeseries",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ml_inference_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Фактическая p95 Латентность",
          "refId": "A"
        },
        {
          "expr": "0.2", 
          "legendFormat": "SLO Target (200ms)",
          "refId": "B",
          "color": "red"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.2 }
            ]
          },
          "thresholdsStyle": { "mode": "line" }
        },
        "overrides": []
      },
      "alert": {
        "name": "SLO Violation Alert",
        "conditions": [
          {
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "avg", "params": [] },
            "evaluator": { "type": "gt", "params": [0.2] },
            "operator": { "type": "and" }
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Пропускная способность (RPS) и Узкое место Postgres",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "expr": "sum(rate(ml_inference_request_duration_seconds_count[5m]))",
          "legendFormat": "Текущий RPS сервиса",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Budget (Остаток бюджета ошибок SLO)",
      "type": "gauge",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(ml_inference_request_duration_seconds_bucket{le=\"0.2\"}[1h])) / sum(rate(ml_inference_request_duration_seconds_count[1h])))) * 100",
          "legendFormat": "Сгорело бюджета (%)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    }
  ]
}
